# Server
PORT=3000
NODE_ENV=development

# Supabase - UPDATE THESE WITH YOUR CREDENTIALS FROM supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT
JWT_SECRET=lucked-in-super-secret-key-change-this-in-production-at-least-32-chars
JWT_EXPIRE=7d

# OAuth - YouTube (add later in Day 2)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback

# OAuth - Instagram (add later in Day 2)
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_client_secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback

# OAuth - TikTok (add later in Day 2)
TIKTOK_CLIENT_ID=your_tiktok_client_id
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/tiktok/callback

# OAuth - Facebook (add later in Day 2)
FACEBOOK_CLIENT_ID=your_facebook_client_id
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/facebook/callback

# Stripe (add later when we build premium tier)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_PREMIUM_PRICE_ID=your_premium_price_id

# Logging
LOG_LEVEL=debug
